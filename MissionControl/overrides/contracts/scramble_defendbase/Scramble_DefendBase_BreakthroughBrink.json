	"dialogueList": [
		{
			"dialogue": {
				"EncounterObjectGuid": "73df8d9c-a274-48fd-98c9-2bd0d7860e83"
			},
			"name": "Dialogue_MissionStart",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "Hot drop went bad, you've scattered forces.  Regroup if able, but priority is unchanged: defend the facility.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_DariusDefault",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "21a03616-c88b-4edd-a9a9-b4dd54b46d6c",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "<color=#99ebff><b>{MC.PlayerLances.TeamPilot_Position_1.DisplayName}</b></color> and <color=#99ebff><b>{MC.PlayerLances.TeamPilot_Position_4.DisplayName}</b></color> are on-site, somewhat.  <color=#99ebff><b>{MC.PlayerLances.TeamPilot_Position_3.DisplayName}</b></color> inbound.  <color=#99ebff><b>{MC.PlayerLances.TeamPilot_Position_2.DisplayName}</b></color> is far out --- moving to assist as able.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Position_1",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "21a03616-c88b-4edd-a9a9-b4dd54b46d6c",
					"cameraDistance": "Medium",
					"cameraHeight": "Default",
					"revealRadius": -1
				},
				{
					"words": "Long walk ahead, but I'm coming.  Hold the line without me.",
					"wordsColor": {
						"r": 1,
						"g": 1,
						"b": 1,
						"a": 1
					},
					"selectedCastDefId": "castDef_TeamPilot_Position_2",
					"emote": "Default",
					"audioName": "NONE",
					"cameraFocusGuid": "5df48a48-1840-49b0-84e9-126847053afa",
					"cameraDistance": "Far",
					"cameraHeight": "Default",
					"revealRadius": -1
				}
			]
		},
		{
