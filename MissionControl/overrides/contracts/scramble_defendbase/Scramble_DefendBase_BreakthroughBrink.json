			},
			"name": "Dialogue_MissionSuccess",
			"overrideDialogueBucketId": "",
			"dialogueContent": [
				{
					"words": "Reinforcements have arrived.  The facility is safe.\n\r\nExcellent work, Commander.  Our employer's research can continue as planned.",
